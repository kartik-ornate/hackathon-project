# ── Raksha frontend configuration (Vite) ────────────────────────────────────
# Copy to .env (or .env.local) and adjust for your deploy.
# All client-exposed vars MUST be prefixed with VITE_.

# Backend WebSocket origin (Tier-2 Reasoner/RAG transport).
# Local dev default is http://localhost:4000. In production set this to your
# deployed backend origin, e.g. https://raksha-api.example.com
VITE_WS_URL=http://localhost:4000

# Base path/URL for the REST API (POST /api/analyze).
# In dev, Vite proxies "/api" to the backend (see vite.config.js), so the
# default below works as-is. For a cross-origin deploy use the full URL,
# e.g. https://raksha-api.example.com/api
VITE_API_BASE=/api
