# ── Raksha backend configuration ───────────────────────────────────────────

# Google Gemini API key — powers Tier-2 (RAG embeddings + LLM Reasoner).
# Without it the backend still boots, but Tier-2 runs in degraded fallback mode.
GEMINI_API_KEY=your_key_here

# Port the backend HTTP + WebSocket server listens on.
PORT=4000

# Gemini model names (Tier-2 only).
CLASSIFIER_MODEL=gemini-2.5-flash
REASONER_MODEL=gemini-2.5-pro
EMBEDDING_MODEL=text-embedding-004

# Comma-separated CORS allow-list (HTTP + WebSocket).
# Defaults to the local dev origins below if unset. Set this for any hosted deploy.
# Example: CORS_ORIGINS=https://raksha.example.com,https://www.raksha.example.com
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
